{
  "name": "njangrent-backend",
  "version": "1.0.0",
  "description": "NjangaRent backend — Node.js/Express/PostgreSQL API for housing in Buea, Cameroon",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "setup": "tsx src/db/migrate.ts && tsx src/db/seed.ts"
  },
  "dependencies": {
    "@clerk/express": "^2.1.31",
    "@supabase/supabase-js": "^2.108.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "typescript": "^5.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
