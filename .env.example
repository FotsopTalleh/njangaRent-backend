# ============================================================
# NjangaRent Backend — Environment Variables
# Copy this file to .env and fill in all values.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/njangrent

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_STRING
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Nkwa Mobile Money ───────────────────────────────────────
NKWA_API_KEY=your_nkwa_api_key
NKWA_API_SECRET=your_nkwa_api_secret
NKWA_WEBHOOK_SECRET=your_nkwa_webhook_secret
NKWA_BASE_URL=https://sandbox.api.nkwa.com

# ── Admin seed ───────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@njangrent.cm
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=NjangaRent Admin

# ── Upload ───────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./public/uploads
