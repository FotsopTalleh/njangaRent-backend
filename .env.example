# ============================================================
# MyTenant Backend — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ── Flask ─────────────────────────────────────────────────
FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING
FRONTEND_URL=http://localhost:3000

# ── JWT ───────────────────────────────────────────────────
# Use separate secrets for access and refresh tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
ACCESS_TOKEN_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING
REFRESH_TOKEN_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_STRING
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# ── Firebase / Firestore ──────────────────────────────────
# Path to your Firebase service account JSON (relative to project root).
# Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── FCM (Firebase Cloud Messaging) ────────────────────────
# Uses the same service account as Firestore — no separate key needed.
FCM_PROJECT_ID=your-firebase-project-id

# ── Google OAuth ──────────────────────────────────────────
# Your Google OAuth 2.0 client ID (Web application type)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Redis ─────────────────────────────────────────────────
# Points to the redis service in Docker Compose network.
# Change to redis://localhost:6379/0 for local dev without Docker.
REDIS_URL=redis://redis:6379/0

# ── n8n ───────────────────────────────────────────────────
# Shared secret for authenticating webhook calls between Flask and n8n.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
N8N_WEBHOOK_SECRET=REPLACE_WITH_32_CHAR_HEX_STRING
# URL Flask uses to trigger n8n (internal Docker Compose DNS).
N8N_OCR_TRIGGER_URL=http://n8n:5678/webhook/ocr-trigger
# URL n8n uses to call back to Flask (internal Docker Compose DNS).
FLASK_INTERNAL_URL=http://flask:5000

# ── Email ─────────────────────────────────────────────────
# Choose: sendgrid | smtp
EMAIL_PROVIDER=sendgrid

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your_sendgrid_api_key

# SMTP fallback (used when EMAIL_PROVIDER=smtp)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password

# Sender identity (both providers)
MAIL_FROM_ADDRESS=noreply@mytenant.app
MAIL_FROM_NAME=MyTenant

# ── Upload limits ──────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Receipt ────────────────────────────────────────────────
RECEIPT_NUMBER_PREFIX=RCT
